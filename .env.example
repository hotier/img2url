# Cloudflare Pages 环境变量配置示例

# R2 存储桶配置
R2_BUCKET_NAME=img2url-images

# Turnstile 验证码配置（可选）
TURNSTILE_SITE_KEY=0x4AAAAAACasWM4vLebpu_B7
TURNSTILE_SECRET_KEY=

# R2 S3 兼容 API 配置
# 你可以在 Cloudflare Dashboard > R2 > Your Bucket > Settings > S3 Compatibility 中获取
R2_S3_ACCESS_KEY_ID=
R2_S3_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com

# API 配置（可选）
CUSTOM_DOMAIN=https://img2url.pages.dev

# Cloudflare Pages 环境变量配置示例
# 在 Cloudflare Dashboard > Pages > Your Project > Settings > Environment variables 中配置

# ===========================================
# 可选配置
# ===========================================

# 自定义域名（如果不设置，将使用请求的 origin）
CUSTOM_DOMAIN=https://your-domain.pages.dev

# Turnstile 人机验证配置
# 获取地址：https://dash.cloudflare.com/?to=/:account/turnstile
# 前端使用（VITE_ 前缀的变量会暴露给前端）
VITE_TURNSTILE_SITE_KEY=0x4AAAAAACasWM4vLebpu_B7
# 后端验证密钥（不要暴露给前端）
TURNSTILE_SECRET_KEY=

# Cloudflare API 配置（用于 sync-stats 接口）
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# R2 S3 兼容 API 配置（可选，用于其他工具访问）
R2_S3_ACCESS_KEY_ID=
R2_S3_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
